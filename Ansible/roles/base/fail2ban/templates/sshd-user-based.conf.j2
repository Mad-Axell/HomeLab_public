# Fail2ban SSH User-based Filter
# Generated by Ansible Role
# Host: {{ inventory_hostname }}
# Generated: {{ ansible_date_time.iso8601 }}

[Definition]

# Prefix line definition
__prefix_line = ^\s*

# SSH user-based protection filter
failregex = ^%(__prefix_line)sFailed password for (invalid user )?{{ user_based_protection.trusted_users | join('|') if user_based_protection.trusted_users | length > 0 else '.*' }} from <HOST> port \d+ ssh2\s*$
            ^%(__prefix_line)sFailed password for (invalid user )?{{ user_based_protection.trusted_users | join('|') if user_based_protection.trusted_users | length > 0 else '.*' }} from <HOST> port \d+ ssh2\s*$
            ^%(__prefix_line)sInvalid user {{ user_based_protection.trusted_users | join('|') if user_based_protection.trusted_users | length > 0 else '.*' }} from <HOST>\s*$
            ^%(__prefix_line)sUser {{ user_based_protection.trusted_users | join('|') if user_based_protection.trusted_users | length > 0 else '.*' }} from <HOST> not allowed because not listed in AllowUsers\s*$
            ^%(__prefix_line)sUser {{ user_based_protection.trusted_users | join('|') if user_based_protection.trusted_users | length > 0 else '.*' }} from <HOST> not allowed because listed in DenyUsers\s*$
            ^%(__prefix_line)sUser {{ user_based_protection.trusted_users | join('|') if user_based_protection.trusted_users | length > 0 else '.*' }} from <HOST> not allowed because not in any group\s*$
            ^%(__prefix_line)srefused connect from <HOST>\s*$
            ^%(__prefix_line)sUser {{ user_based_protection.trusted_users | join('|') if user_based_protection.trusted_users | length > 0 else '.*' }} from <HOST> not allowed because a group is listed in DenyGroups\s*$
            ^%(__prefix_line)sUser {{ user_based_protection.trusted_users | join('|') if user_based_protection.trusted_users | length > 0 else '.*' }} from <HOST> not allowed because none of user's groups are listed in AllowGroups\s*$

# Ignore regex patterns
ignoreregex = 

# Date pattern
datepattern = ^%%Y-%%m-%%d %%H:%%M:%%S
