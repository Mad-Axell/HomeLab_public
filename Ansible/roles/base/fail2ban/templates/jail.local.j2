# Fail2Ban Jail Configuration
# Generated by Ansible role: base/fail2ban

[DEFAULT]
# Global configuration
ignoreip = {{ fail2ban_ignoreip | join(' ') }}
bantime = 3600
findtime = 600
maxretry = 3
backend = auto
usedns = warn
logencoding = auto
enabled = false
mode = normal
filter = %(__name__)s
logpath = /dev/null
maxmatches = %(maxretry)s
ignorecommand =
failregex = ^<HOST> .*$
ignoreregex =
destemail = root@localhost
sender = root@<fq-hostname>
mta = sendmail
protocol = tcp
chain = <known/chain>
port = 0
banaction = %(banaction_allports)s
banaction_allports = ufw
action_ = %(banaction)s[name=%(__name__)s, bantime="%(bantime)s", port="%(port)s", protocol="%(protocol)s", chain="%(chain)s"]
action_mw = %(banaction)s[name=%(__name__)s, bantime="%(bantime)s", port="%(port)s", protocol="%(protocol)s", chain="%(chain)s"]
         %(mta)s-whois[name=%(__name__)s, sender="%(sender)s", dest="%(destemail)s", protocol="%(protocol)s", chain="%(chain)s"]
action_mwl = %(banaction)s[name=%(__name__)s, bantime="%(bantime)s", port="%(port)s", protocol="%(protocol)s", chain="%(chain)s"]
          %(mta)s-whois-lines[name=%(__name__)s, sender="%(sender)s", dest="%(destemail)s", logpath=%(logpath)s, chain="%(chain)s"]
action = %(action_)s

{% for jail_name, jail_config in fail2ban_jails.items() %}
[{{ jail_name }}]
enabled = {{ jail_config.enabled | lower }}
port = {{ jail_config.port }}
filter = {{ jail_config.filter }}
logpath = {{ jail_config.logpath }}
maxretry = {{ jail_config.maxretry }}
findtime = {{ jail_config.findtime }}
bantime = {{ jail_config.bantime }}
banaction = {{ jail_config.banaction }}
ignoreip = {{ jail_config.ignoreip }}

{% endfor %}

{% for jail_name, jail_config in fail2ban_additional_jails.items() %}
[{{ jail_name }}]
enabled = {{ jail_config.enabled | lower }}
port = {{ jail_config.port }}
filter = {{ jail_config.filter }}
logpath = {{ jail_config.logpath }}
maxretry = {{ jail_config.maxretry }}
findtime = {{ jail_config.findtime }}
bantime = {{ jail_config.bantime }}
banaction = {{ jail_config.banaction }}

{% endfor %}
