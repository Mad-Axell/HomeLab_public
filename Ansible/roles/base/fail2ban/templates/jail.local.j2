# Fail2ban Jail Configuration File
# Generated by Ansible Role
# Host: {{ inventory_hostname }}
# OS: {{ ansible_os_family }} {{ ansible_distribution }} {{ ansible_distribution_version }}
# Generated: {{ ansible_date_time.iso8601 }}

[DEFAULT]

# Default ban time
bantime = {{ fail2ban_config.bantime }}

# Default find time
findtime = {{ fail2ban_config.findtime }}

# Default max retry
maxretry = {{ fail2ban_config.maxretry }}

# Default action
action = {{ fail2ban_config.action }}

# Ignore IP addresses (configured below in whitelist section)

# Whitelist configuration
{% set default_ignore_ips = [] %}
{% if fail2ban_config.ignoreip | length > 0 %}
{% set default_ignore_ips = default_ignore_ips + fail2ban_config.ignoreip %}
{% endif %}
{% if ssh_protection.whitelist_enabled | bool %}
{% if ssh_protection.whitelist_ips | length > 0 %}
{% set default_ignore_ips = default_ignore_ips + ssh_protection.whitelist_ips %}
{% endif %}
{% if ssh_protection.whitelist_networks | length > 0 %}
{% set default_ignore_ips = default_ignore_ips + ssh_protection.whitelist_networks %}
{% endif %}
{% endif %}
{% if user_based_protection.enabled | bool %}
{% if user_based_protection.trusted_networks | length > 0 %}
{% set default_ignore_ips = default_ignore_ips + user_based_protection.trusted_networks %}
{% endif %}
{% endif %}
{% if default_ignore_ips | length > 0 %}
ignoreip = {{ default_ignore_ips | join(' ') }}
{% endif %}

# Email notifications
{% if email_notifications.enabled | bool %}
destemail = {{ email_notifications.destemail }}
sender = {{ email_notifications.sender }}
action = {{ email_notifications.action }}
{% endif %}

# Firewall integration
{% if firewall_integration.enabled | bool %}
# Firewall backend
firewall_backend = {{ firewall_integration.firewall_backend }}

# Firewall chain
firewall_chain = {{ firewall_integration.firewall_chain }}
{% endif %}

# SSH Protection Jail
{% if ssh_protection.enabled | bool %}
[sshd]
enabled = true
port = {{ ssh_protection.port }}
protocol = {{ ssh_protection.protocol }}
{% if user_based_protection.enabled | bool %}
filter = sshd-user-based
{% else %}
filter = sshd
{% endif %}
logpath = /var/log/auth.log
maxretry = {{ ssh_protection.maxretry }}
bantime = {{ ssh_protection.bantime }}
findtime = {{ ssh_protection.findtime }}

# SSH Whitelist
{% if ssh_protection.whitelist_enabled | bool %}
{% set ssh_ignore_ips = [] %}
{% if ssh_protection.whitelist_ips | length > 0 %}
{% set ssh_ignore_ips = ssh_ignore_ips + ssh_protection.whitelist_ips %}
{% endif %}
{% if ssh_protection.whitelist_networks | length > 0 %}
{% set ssh_ignore_ips = ssh_ignore_ips + ssh_protection.whitelist_networks %}
{% endif %}
{% if ssh_ignore_ips | length > 0 %}
ignoreip = {{ ssh_ignore_ips | join(' ') }}
{% endif %}
{% endif %}

# SSH Action
{% if email_notifications.enabled | bool %}
action = {{ email_notifications.action }}
{% else %}
action = {{ fail2ban_config.action }}
{% endif %}
{% endif %}

# Additional Jails
{% for jail_name, jail_config in additional_jails.items() %}
{% if jail_config.enabled | bool %}
[{{ jail_name }}]
enabled = true
port = {{ jail_config.port }}
filter = {{ jail_config.filter }}
logpath = {{ jail_config.logpath }}
maxretry = {{ jail_config.maxretry }}
bantime = {{ jail_config.bantime }}
findtime = {{ jail_config.findtime }}
action = {{ fail2ban_config.action }}
{% endif %}
{% endfor %}

# Custom Jails
{% for jail_config in advanced_settings.custom_jails %}
[{{ jail_config.name }}]
enabled = {{ jail_config.enabled | default(true) }}
port = {{ jail_config.port }}
filter = {{ jail_config.filter }}
logpath = {{ jail_config.logpath }}
maxretry = {{ jail_config.maxretry | default(fail2ban_config.maxretry) }}
bantime = {{ jail_config.bantime | default(fail2ban_config.bantime) }}
findtime = {{ jail_config.findtime | default(fail2ban_config.findtime) }}
action = {{ jail_config.action | default(fail2ban_config.action) }}
{% if jail_config.ignoreip is defined %}
ignoreip = {{ jail_config.ignoreip | join(' ') }}
{% endif %}
{% endfor %}
