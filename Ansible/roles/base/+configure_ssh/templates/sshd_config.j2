# =============================================================================
# SSH Server Configuration File
# =============================================================================
# Generated by Ansible template: sshd_config.j2
# =============================================================================

# Basic SSH Settings / Основные настройки SSH
Port {{ ssh_port }}
Protocol {{ ssh_security.protocol }}

# Host keys / Ключи хоста (MUST be before Match blocks!)
{% for key_type in ['rsa', 'ecdsa', 'ed25519'] %}
{% if ansible_os_family == "Debian" %}
HostKey /etc/ssh/ssh_host_{{ key_type }}_key
{% elif ansible_os_family == "RedHat" %}
HostKey /etc/ssh/ssh_host_{{ key_type }}_key
{% elif ansible_os_family == "Suse" %}
HostKey /etc/ssh/ssh_host_{{ key_type }}_key
{% endif %}
{% endfor %}

# Authentication settings / Настройки аутентификации
PasswordAuthentication {{ ssh_security.password_authentication }}
PubkeyAuthentication {{ ssh_security.pubkey_authentication }}
PermitEmptyPasswords {{ ssh_security.permit_empty_passwords }}
PermitRootLogin {{ ssh_security.permit_root_login }}
MaxAuthTries {{ ssh_security.max_auth_tries }}
LoginGraceTime {{ ssh_security.login_grace_time }}

# Client connection settings / Настройки подключения клиента
ClientAliveInterval {{ ssh_security.client_alive_interval }}
ClientAliveCountMax {{ ssh_security.client_alive_count_max }}

# Logging settings / Настройки логирования
LogLevel {{ ssh_security.log_level }}
SyslogFacility {{ ssh_security.syslog_facility }}

# Banner / Баннер
{% if ssh_banner_file is defined %}
Banner {{ ssh_banner_file }}
{% endif %}
PrintLastLog {{ ssh_security.print_last_log }}

# Advanced settings / Расширенные настройки
Compression {{ ssh_advanced.compression }}
X11Forwarding {{ 'yes' if ssh_advanced.x11_forwarding else 'no' }}
{% if ssh_advanced.x11_forwarding %}
X11DisplayOffset {{ ssh_advanced.x11_display_offset }}
X11UseLocalhost {{ 'yes' if ssh_advanced.x11_use_localhost else 'no' }}
{% endif %}
AllowTcpForwarding {{ 'yes' if ssh_advanced.allow_tcp_forwarding else 'no' }}
GatewayPorts {{ 'yes' if ssh_advanced.gateway_ports else 'no' }}
AllowAgentForwarding {{ 'yes' if ssh_advanced.allow_agent_forwarding else 'no' }}

# Cryptographic settings / Криптографические настройки
HostKeyAlgorithms {{ ssh_security.host_key_algorithms }}
KexAlgorithms {{ ssh_security.kex_algorithms }}
Ciphers {{ ssh_security.ciphers }}
MACs {{ ssh_security.macs }}

# Subsystem settings / Настройки подсистем
{% if ssh_advanced.subsystem_sftp is defined %}
Subsystem sftp {{ ssh_advanced.subsystem_sftp }}
{% else %}
# Default SFTP subsystem based on OS / Подсистема SFTP по умолчанию для ОС
{% if ansible_os_family == "Debian" %}
Subsystem sftp /usr/lib/openssh/sftp-server
{% elif ansible_os_family == "RedHat" %}
Subsystem sftp /usr/libexec/openssh/sftp-server
{% elif ansible_os_family == "Suse" %}
Subsystem sftp /usr/lib/ssh/sftp-server
{% endif %}
{% endif %}

# Network-based access control / Контроль доступа на основе сети
{% if ssh_advanced.use_match_blocks and final_allowed_subnets is defined and final_allowed_subnets | length > 0 %}

# Match block for trusted networks / Блок Match для доверенных сетей
Match Address {{ final_allowed_subnets | join(',') }}
    PasswordAuthentication {{ 'yes' if ssh_access_control.trusted_networks_password_auth else 'no' }}
    PubkeyAuthentication yes
{% endif %}

{% if ssh_advanced.use_match_blocks and final_denied_subnets is defined and final_denied_subnets | length > 0 %}

# Match block for denied networks / Блок Match для запрещенных сетей
Match Address {{ final_denied_subnets | join(',') }}
    DenyUsers *
{% endif %}

{% if ssh_advanced.use_match_blocks and final_not_trusted_subnets is defined and final_not_trusted_subnets | length > 0 %}

# Match block for not trusted networks / Блок Match для недоверенных сетей
Match Address {{ final_not_trusted_subnets | join(',') }}
    PasswordAuthentication {{ 'yes' if ssh_access_control.untrusted_networks_require_both else 'no' }}
    PubkeyAuthentication {{ 'yes' if ssh_access_control.untrusted_networks_require_both else 'no' }}
    MaxAuthTries {{ ssh_security.max_auth_tries }}
{% endif %}


# Include system-specific configurations / Включить специфичные настройки системы
{% if ansible_os_family == "Debian" %}
# Debian/Ubuntu specific settings
AcceptEnv LANG LC_*
{% elif ansible_os_family == "RedHat" %}
# RedHat/CentOS specific settings  
AcceptEnv LANG LC_CTYPE LC_NUMERIC LC_TIME LC_COLLATE LC_MONETARY LC_MESSAGES
AcceptEnv LC_PAPER LC_NAME LC_ADDRESS LC_TELEPHONE LC_MEASUREMENT
AcceptEnv LC_IDENTIFICATION LC_ALL LANGUAGE
AcceptEnv XMODIFIERS
{% elif ansible_os_family == "Suse" %}
# SUSE specific settings
AcceptEnv LANG LC_CTYPE LC_NUMERIC LC_TIME LC_COLLATE LC_MONETARY LC_MESSAGES
AcceptEnv LC_PAPER LC_NAME LC_ADDRESS LC_TELEPHONE LC_MEASUREMENT
AcceptEnv LC_IDENTIFICATION LC_ALL
{% endif %}

# User and group restrictions / Ограничения пользователей и групп
{% if users_to_add is defined and users_to_add | length > 0 %}
# Allow specific users / Разрешить определенных пользователей
AllowUsers {% for user in users_to_add %}{{ user.username }} {% endfor %}

{% endif %}

# End of SSH configuration / Конец конфигурации SSH
