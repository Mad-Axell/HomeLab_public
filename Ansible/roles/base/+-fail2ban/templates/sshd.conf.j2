# =============================================================================
# Fail2ban SSH Jail Configuration
# Host: {{ inventory_hostname }}
# =============================================================================
# Generated by Ansible template: sshd.conf.j2
# =============================================================================

[sshd]

# Enable SSH protection
enabled = true

# SSH port
port = {{ ssh_protection.port }}

# SSH protocol
protocol = {{ ssh_protection.protocol }}

# SSH filter
{% if user_based_protection.enabled | bool %}
filter = sshd-user-based
{% else %}
filter = sshd
{% endif %}

# SSH log path
{% if ansible_os_family == "Debian" %}
logpath = /var/log/auth.log
{% elif ansible_os_family == "RedHat" %}
logpath = /var/log/secure
{% elif ansible_os_family == "Suse" %}
logpath = /var/log/messages
{% else %}
logpath = /var/log/auth.log
{% endif %}

# SSH protection settings
maxretry = {{ ssh_protection.maxretry }}
bantime = {{ ssh_protection.bantime }}
findtime = {{ ssh_protection.findtime }}

# SSH whitelist and user-based protection / Белый список SSH и защита на основе пользователей
{% set ssh_ignore_ips = [] %}
{% if ssh_protection.whitelist_enabled | bool %}
  {% if ssh_protection.whitelist_ips | length > 0 %}
    {% set ssh_ignore_ips = ssh_ignore_ips + ssh_protection.whitelist_ips %}
  {% endif %}
  {% if ssh_protection.whitelist_networks | length > 0 %}
    {% set ssh_ignore_ips = ssh_ignore_ips + ssh_protection.whitelist_networks %}
  {% endif %}
{% endif %}
{% if user_based_protection.enabled | bool %}
  {% if user_based_protection.trusted_networks | length > 0 %}
    {% set ssh_ignore_ips = ssh_ignore_ips + user_based_protection.trusted_networks %}
  {% endif %}
{% endif %}
{% if ssh_ignore_ips | length > 0 %}
ignoreip = {{ ssh_ignore_ips | unique | join(' ') }}
{% endif %}

# SSH action
{% if email_notifications.enabled | bool %}
action = {{ email_notifications.action }}
{% else %}
action = {{ fail2ban_config.action }}
{% endif %}

# SSH ban action
banaction = iptables-multiport

# SSH unban action
unbanaction = iptables-multiport

# SSH backend (with journalflags for systemd journal support)
backend = systemd[journalflags=1]

# SSH additional settings
{% if firewall_integration.enabled | bool %}
# Firewall integration
firewall_backend = {{ firewall_integration.firewall_backend }}
firewall_chain = {{ firewall_integration.firewall_chain }}
{% endif %}

# SSH performance settings
{% if performance_settings.max_memory is defined %}
max_memory = {{ performance_settings.max_memory }}
{% endif %}

{% if performance_settings.max_threads is defined %}
max_threads = {{ performance_settings.max_threads }}
{% endif %}

# SSH security settings
{% if security_settings.selinux_enabled | bool %}
# SELinux context
selinux_context = {{ security_settings.selinux_context }}
{% endif %}

# SSH debug settings
{% if debug_mode | bool %}
debug_mode = true
{% endif %}

# SSH validation settings
{% if validate_parameters | bool %}
validate_parameters = true
{% endif %}

{% if strict_validation | bool %}
strict_validation = true
{% endif %}
