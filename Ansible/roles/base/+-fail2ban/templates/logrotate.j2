# Fail2ban Logrotate Configuration
# Generated by Ansible Role
# Host: {{ inventory_hostname }}
# Generated: {{ ansible_date_time.iso8601 }}

{{ fail2ban_config.logtarget }} {
    daily
    missingok
    rotate 7
    compress
    delaycompress
    notifempty
    create 644 root root
    postrotate
        /bin/systemctl reload fail2ban > /dev/null 2>&1 || true
    endscript
}

# Fail2ban database rotation
{{ fail2ban_config.dbfile }} {
    weekly
    missingok
    rotate 4
    compress
    delaycompress
    notifempty
    create 644 root root
    postrotate
        /bin/systemctl reload fail2ban > /dev/null 2>&1 || true
    endscript
}
