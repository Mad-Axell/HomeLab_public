# Fail2ban Main Configuration File
# Generated by Ansible Role
# Host: {{ inventory_hostname }}
# OS: {{ ansible_os_family }} {{ ansible_distribution }} {{ ansible_distribution_version }}
# Generated: {{ ansible_date_time.iso8601 }}

[Definition]

# Log level
loglevel = {{ fail2ban_config.loglevel }}

# Log target
logtarget = {{ fail2ban_config.logtarget }}

# Socket file
socket = {{ fail2ban_config.socket }}

# PID file
pidfile = {{ fail2ban_config.pidfile }}

# System log socket
syslogsocket = {{ fail2ban_config.syslogsocket }}

# DNS resolution
usedns = {{ fail2ban_config.usedns }}

# iptables chain
chain = {{ fail2ban_config.chain }}

# Default port
port = {{ fail2ban_config.port }}

# Database file
dbfile = {{ fail2ban_config.dbfile }}

# Database purge age
dbpurgeage = {{ fail2ban_config.dbpurgeage }}

# NOTE: Jail parameters (bantime, findtime, maxretry, action, ignoreip) 
# are configured in jail.local, not in fail2ban.conf
# Jail параметры (bantime, findtime, maxretry, action, ignoreip)
# настраиваются в jail.local, а не в fail2ban.conf

# Performance settings
{% if performance_settings.max_memory is defined %}
max_memory = {{ performance_settings.max_memory }}
{% endif %}

{% if performance_settings.max_threads is defined %}
max_threads = {{ performance_settings.max_threads }}
{% endif %}

{% if performance_settings.db_max_connections is defined %}
db_max_connections = {{ performance_settings.db_max_connections }}
{% endif %}

# Security settings
{% if security_settings.selinux_enabled | bool %}
# SELinux context
selinux_context = {{ security_settings.selinux_context }}
{% endif %}

# Email notifications
{% if email_notifications.enabled | bool %}
destemail = {{ email_notifications.destemail }}
sender = {{ email_notifications.sender }}
action = {{ email_notifications.action }}
{% endif %}

# Firewall integration
{% if firewall_integration.enabled | bool %}
# Firewall backend
firewall_backend = {{ firewall_integration.firewall_backend }}

# Firewall chain
firewall_chain = {{ firewall_integration.firewall_chain }}
{% endif %}

# System integration
{% if system_integration.systemd_enabled | bool %}
# Systemd integration
systemd_enabled = true
{% endif %}

{% if system_integration.logrotate_enabled | bool %}
# Log rotation
logrotate_enabled = true
{% endif %}

# Backup settings
{% if backup_enabled | bool %}
backup_enabled = true
backup_dir = {{ backup_settings.backup_dir }}
backup_retention = {{ backup_settings.backup_retention }}
{% if backup_settings.backup_compress | bool %}
backup_compress = true
{% endif %}
{% endif %}

# Debug settings
{% if debug_mode | bool %}
debug_mode = true
{% endif %}

# Validation settings
{% if validate_parameters | bool %}
validate_parameters = true
{% endif %}

{% if strict_validation | bool %}
strict_validation = true
{% endif %}
