#!/bin/bash
# Скрипт управления SSH доступом
# Generated by Ansible role configure_pam
# Date: {{ ansible_date_time.iso8601 }}

ACCESS_FILE="{{ pam_access_file }}"
SSH_USERS_FILE="{{ pam_ssh_users_file }}"
DENIED_USERS_FILE="{{ pam_denied_users_file }}"

case "$1" in
  "add")
    if [ -z "$2" ] || [ -z "$3" ]; then
      echo "Использование: $0 add <user> <subnet>"
      exit 1
    fi
    echo "+ : $2 : $3" >> "$ACCESS_FILE"
    if ! grep -q "^$2$" "$SSH_USERS_FILE"; then
      echo "$2" >> "$SSH_USERS_FILE"
    fi
    echo "Добавлен пользователь $2 с доступом из $3"
    ;;
  "remove")
    if [ -z "$2" ]; then
      echo "Использование: $0 remove <user>"
      exit 1
    fi
    sed -i "/^+ : $2 :/d" "$ACCESS_FILE"
    sed -i "/^$2$/d" "$SSH_USERS_FILE"
    echo "Удален пользователь $2"
    ;;
  "add-user")
    if [ -z "$2" ] || [ -z "$3" ] || [ -z "$4" ]; then
      echo "Использование: $0 add-user <user> <password> <subnet>"
      exit 1
    fi
    useradd -m -s /bin/bash "$2"
    echo "$2:$3" | chpasswd
    usermod -aG {{ pam_wheel_group }} "$2"
    echo "+ : $2 : $4" >> "$ACCESS_FILE"
    if ! grep -q "^$2$" "$SSH_USERS_FILE"; then
      echo "$2" >> "$SSH_USERS_FILE"
    fi
    echo "Создан пользователь $2 с доступом из $4"
    ;;
  "deny")
    if [ -z "$2" ] || [ -z "$3" ]; then
      echo "Использование: $0 deny <user> <subnet>"
      exit 1
    fi
    echo "- : $2 : $3" >> "$ACCESS_FILE"
    echo "Запрещен доступ пользователю $2 из $3"
    ;;
  "deny-user")
    if [ -z "$2" ]; then
      echo "Использование: $0 deny-user <user>"
      exit 1
    fi
    if ! grep -q "^$2$" "$DENIED_USERS_FILE"; then
      echo "$2" >> "$DENIED_USERS_FILE"
    fi
    echo "Пользователь $2 добавлен в список запрещенных"
    ;;
  "allow-user")
    if [ -z "$2" ]; then
      echo "Использование: $0 allow-user <user>"
      exit 1
    fi
    sed -i "/^$2$/d" "$DENIED_USERS_FILE"
    echo "Пользователь $2 удален из списка запрещенных"
    ;;
  "list")
    echo "Разрешенные пользователи:"
    cat "$SSH_USERS_FILE"
    echo ""
    echo "Правила доступа:"
    cat "$ACCESS_FILE"
    echo ""
    echo "Запрещенные пользователи:"
    cat "$DENIED_USERS_FILE"
    ;;
  "reload")
    systemctl restart ssh
    echo "SSH перезапущен"
    ;;
  "test")
    if [ -z "$2" ] || [ -z "$3" ]; then
      echo "Использование: $0 test <user> <ip>"
      exit 1
    fi
    echo "Тестирование доступа пользователя $2 с IP $3"
    pam_access -v -u "$2" -r "$3"
    ;;
  *)
    echo "Использование: $0 {add|remove|add-user|deny|deny-user|allow-user|list|reload|test}"
    echo "  add <user> <subnet>        - добавить пользователя с доступом из подсети"
    echo "  remove <user>              - удалить пользователя"
    echo "  add-user <user> <pass> <subnet> - создать пользователя с доступом"
    echo "  deny <user> <subnet>       - запретить доступ пользователю из подсети"
    echo "  deny-user <user>           - запретить доступ пользователю"
    echo "  allow-user <user>          - разрешить доступ пользователю"
    echo "  list                       - показать текущие правила"
    echo "  reload                     - перезапустить SSH"
    echo "  test <user> <ip>           - протестировать доступ пользователя с IP"
    ;;
esac
