<?php
/*
 * EN: Rendered by Ansible role pfsense-config — DHCP server (kea backend).
 * RU: Сгенерировано ролью Ansible pfsense-config — DHCP-сервер (бэкенд kea).
 * Usage: php -f this.php <apply>   (apply: 1 = write & apply, 0 = dry-run report)
 */
require_once('/etc/inc/config.inc');
require_once('/etc/inc/util.inc');
require_once('/etc/inc/functions.inc');
require_once('/etc/inc/services.inc');

global $config;
$apply   = (isset($argv[1]) && $argv[1] === '1');
$changed = false;

function set_val(&$arr, $key, $val, &$changed) {
    $cur = isset($arr[$key]) ? (string)$arr[$key] : null;
    if ($cur !== (string)$val) { $arr[$key] = (string)$val; $changed = true; }
}
function set_flag(&$arr, $key, $on, &$changed) {
    $cur = array_key_exists($key, $arr);
    if ($on && !$cur)  { $arr[$key] = ''; $changed = true; }
    if (!$on && $cur)  { unset($arr[$key]); $changed = true; }
}

/* EN: desired DHCP state from host_vars / RU: желаемое состояние DHCP из host_vars */
$desired = array(
{% for d in pfsense_dhcp_servers %}
    '{{ d.interface }}' => array(
        'enable' => {{ 'true' if d.enable else 'false' }},
        'from'   => '{{ d.range_from }}',
        'to'     => '{{ d.range_to }}',
        'dns'    => array({% for s in d.dns_servers %}'{{ s }}'{{ ', ' if not loop.last else '' }}{% endfor %}),
    ),
{% endfor %}
);

/* ---- DHCP backend ---- */
set_val($config, 'dhcpbackend', '{{ pfsense_dhcp_backend }}', $changed);

if (!is_array($config['dhcpd'])) { $config['dhcpd'] = array(); }

foreach ($desired as $if => $d) {
    if (!is_array($config['dhcpd'][$if])) { $config['dhcpd'][$if] = array(); }
    if (!is_array($config['dhcpd'][$if]['range'])) { $config['dhcpd'][$if]['range'] = array(); }

    set_val($config['dhcpd'][$if]['range'], 'from', $d['from'], $changed);
    set_val($config['dhcpd'][$if]['range'], 'to',   $d['to'],   $changed);
    set_flag($config['dhcpd'][$if], 'enable', $d['enable'], $changed);

    $cur_dns = isset($config['dhcpd'][$if]['dnsserver']) ? (array)$config['dhcpd'][$if]['dnsserver'] : array();
    if ($cur_dns !== $d['dns']) {
        $config['dhcpd'][$if]['dnsserver'] = $d['dns'];
        $changed = true;
    }
}

if ($changed) {
    if ($apply) {
        write_config("{{ pfsense_change_reason }} (dhcp)");
        if (function_exists('services_dhcpd_configure')) { services_dhcpd_configure(); }
    }
    echo "{{ pfsense_changed_marker }}\n";
} else {
    echo "{{ pfsense_unchanged_marker }}\n";
}
