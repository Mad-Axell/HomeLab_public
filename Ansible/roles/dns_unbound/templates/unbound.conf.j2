# =============================================================================
# Unbound configuration for dns_unbound role
# Конфигурация Unbound для роли dns_unbound
# {{ ansible_managed }}
# =============================================================================

server:
    # -------------------------------------------------------------------------
    # Network / Сеть
    # -------------------------------------------------------------------------
    interface: {{ unbound_interface }}
    port: {{ unbound_port }}

    # Protocols / Протоколы
    do-ip4: {{ unbound_do_ip4 | default('yes') }}
    do-ip6: {{ unbound_do_ip6 | default('no') }}
    do-udp: {{ unbound_do_udp | default('yes') }}
    do-tcp: {{ unbound_do_tcp | default('yes') }}

    # -------------------------------------------------------------------------
    # Performance / Производительность
    # -------------------------------------------------------------------------
    num-threads: {{ unbound_num_threads }}

    # Cache slabs (power of 2, close to num-threads)
    msg-cache-slabs: {{ unbound_msg_cache_slabs }}
    rrset-cache-slabs: {{ unbound_rrset_cache_slabs }}
    infra-cache-slabs: {{ unbound_infra_cache_slabs }}
    key-cache-slabs: {{ unbound_key_cache_slabs }}

    # Socket buffers
    so-rcvbuf: {{ unbound_so_rcvbuf }}
    so-sndbuf: {{ unbound_so_sndbuf }}

    # -------------------------------------------------------------------------
    # Cache / Кэширование
    # -------------------------------------------------------------------------
    msg-cache-size: {{ unbound_msg_cache_size }}
    rrset-cache-size: {{ unbound_rrset_cache_size }}
    cache-min-ttl: {{ unbound_cache_min_ttl }}
    cache-max-ttl: {{ unbound_cache_max_ttl }}
    neg-cache-size: {{ unbound_neg_cache_size }}

    # -------------------------------------------------------------------------
    # DNSSEC
    # -------------------------------------------------------------------------
{% if unbound_dnssec_enabled %}
    auto-trust-anchor-file: "{{ unbound_trust_anchor }}"
{% if unbound_harden_dnssec_stripped %}
    harden-dnssec-stripped: yes
{% endif %}
{% if unbound_harden_glue %}
    harden-glue: yes
{% endif %}
{% if unbound_harden_below_nxdomain %}
    harden-below-nxdomain: yes
{% endif %}
{% endif %}

    # -------------------------------------------------------------------------
    # Security Hardening / Усиление безопасности
    # -------------------------------------------------------------------------
{% if unbound_hide_identity %}
    hide-identity: yes
{% endif %}
{% if unbound_hide_version %}
    hide-version: yes
{% endif %}

{% if unbound_qname_minimisation %}
    # QNAME minimisation (RFC 7816)
    qname-minimisation: yes
{% endif %}

{% if unbound_use_caps_for_id %}
    # CAPS randomization (cache poisoning protection)
    use-caps-for-id: yes
{% endif %}

{% if unbound_harden_referral_path %}
    harden-referral-path: yes
{% endif %}

{% if unbound_harden_algo_downgrade %}
    harden-algo-downgrade: yes
{% endif %}

{% if unbound_harden_short_bufsize %}
    harden-short-bufsize: yes
{% endif %}

{% if unbound_harden_large_queries %}
    harden-large-queries: yes
{% endif %}

{% if unbound_val_clean_additional %}
    val-clean-additional: yes
{% endif %}

{% if unbound_aggressive_nsec %}
    # Aggressive NSEC (RFC 8198) - better NXDOMAIN caching
    aggressive-nsec: yes
{% endif %}

    # Unwanted reply threshold
    unwanted-reply-threshold: {{ unbound_unwanted_reply_threshold }}

    # -------------------------------------------------------------------------
    # Rate Limiting / Ограничение частоты (DDoS protection)
    # -------------------------------------------------------------------------
{% if unbound_rate_limit > 0 %}
    ratelimit: {{ unbound_rate_limit }}
    ratelimit-size: {{ unbound_rate_limit_size }}
    ratelimit-slabs: {{ unbound_rate_limit_slabs }}
{% endif %}

    # -------------------------------------------------------------------------
    # Optimization / Оптимизация
    # -------------------------------------------------------------------------
{% if unbound_prefetch %}
    prefetch: yes
{% endif %}
{% if unbound_prefetch_key %}
    prefetch-key: yes
{% endif %}

{% if unbound_serve_expired %}
    # Serve expired (respond with stale cache while refreshing)
    serve-expired: yes
    serve-expired-ttl: {{ unbound_serve_expired_ttl }}
{% endif %}

    # EDNS buffer size
    edns-buffer-size: {{ unbound_edns_buffer_size }}

    # Root hints file
    root-hints: "{{ unbound_root_hints }}"

    # -------------------------------------------------------------------------
    # Logging / Логирование
    # -------------------------------------------------------------------------
    verbosity: {{ unbound_verbosity }}
{% if unbound_log_queries %}
    log-queries: yes
{% endif %}
{% if unbound_log_replies %}
    log-replies: yes
{% endif %}
{% if unbound_log_local_actions %}
    log-local-actions: yes
{% endif %}
{% if unbound_log_servfail %}
    log-servfail: yes
{% endif %}

    # -------------------------------------------------------------------------
    # Access Control / Контроль доступа
    # -------------------------------------------------------------------------
{% for acl in unbound_access_control %}
    access-control: {{ acl.subnet }} {{ acl.action }}
{% endfor %}

    # -------------------------------------------------------------------------
    # Private Addresses / Приватные адреса (DNS rebinding protection)
    # -------------------------------------------------------------------------
{% for addr in unbound_private_addresses %}
    private-address: {{ addr }}
{% endfor %}

{% if unbound_local_zones is defined %}
    # -------------------------------------------------------------------------
    # Local Zones / Локальные зоны
    # -------------------------------------------------------------------------
{% for zone in unbound_local_zones %}
    local-zone: "{{ zone.name }}" {{ zone.type }}
{% endfor %}
{% endif %}

{% if unbound_local_data is defined %}
    # Local data records / Локальные DNS записи
{% for data in unbound_local_data %}
    local-data: "{{ data }}"
{% endfor %}
{% endif %}

{% if unbound_local_data_ptr is defined %}
    # Reverse DNS records / Обратные DNS записи
{% for ptr in unbound_local_data_ptr %}
    local-data-ptr: "{{ ptr }}"
{% endfor %}
{% endif %}

# =============================================================================
# Remote Control / Удалённое управление (для кэша)
# =============================================================================
remote-control:
    control-enable: yes
    control-interface: 127.0.0.1
    control-use-cert: no

{% if unbound_use_forward_zone %}
# =============================================================================
# Forward Zone / Зона пересылки
# =============================================================================
forward-zone:
    name: "."
{% if unbound_forward_tls %}
    forward-tls-upstream: yes
{% endif %}
{% for server in unbound_forward_servers %}
    forward-addr: {{ server.addr }}{% if server.name is defined %}#{{ server.name }}{% endif %}

{% endfor %}
{% endif %}

{% if unbound_conditional_forward is defined %}
# =============================================================================
# Conditional Forward Zones / Зоны условной пересылки
# =============================================================================
{% for zone in unbound_conditional_forward %}
forward-zone:
    name: "{{ zone.zone }}"
    forward-addr: {{ zone.forward_addr }}
{% endfor %}
{% endif %}
