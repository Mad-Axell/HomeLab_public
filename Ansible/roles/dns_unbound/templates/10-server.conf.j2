### EN: managed by Ansible (role: unbound) — do NOT edit by hand
### RU: управляется Ansible (роль: unbound) — НЕ редактировать вручную
server:
  username: "unbound"
  directory: "/etc/unbound"
  chroot: ""
  pidfile: "/run/unbound.pid"
  use-syslog: yes
  verbosity: {{ unbound_verbosity }}

  interface: 127.0.0.1@{{ dns.unbound_local_port }}
  do-ip4: yes
  do-ip6: {{ 'yes' if ipv6_enabled else 'no' }}
  do-udp: yes
  do-tcp: yes
  prefer-ip4: yes

  access-control: 127.0.0.0/8 allow
  access-control: 0.0.0.0/0 refuse

  auto-trust-anchor-file: "/var/lib/unbound/root.key"
  root-hints: "/var/lib/unbound/root.hints"
  harden-dnssec-stripped: yes
  harden-glue: yes
  harden-below-nxdomain: yes
  module-config: "validator iterator"

  qname-minimisation: yes
  hide-identity: yes
  hide-version: yes
  aggressive-nsec: yes
  minimal-responses: yes

  ratelimit: {{ unbound_ratelimit }}
  ip-ratelimit: {{ unbound_ip_ratelimit }}

  num-threads: {{ unbound_num_threads }}
  msg-cache-size: {{ unbound_msg_cache_size }}
  rrset-cache-size: {{ unbound_rrset_cache_size }}
  prefetch: yes
  prefetch-key: yes
  serve-expired: yes
  serve-expired-ttl: 3600
  cache-min-ttl: 0
  cache-max-ttl: 86400

  edns-buffer-size: 1232
  so-reuseport: yes
{% if unbound_so_rcvbuf is defined and unbound_so_rcvbuf | string != '0' %}
  so-rcvbuf: {{ unbound_so_rcvbuf }}
{% endif %}
{% if unbound_so_sndbuf is defined and unbound_so_sndbuf | string != '0' %}
  so-sndbuf: {{ unbound_so_sndbuf }}
{% endif %}

  # приватные адреса не утекают наружу
  private-address: 10.0.0.0/8
  private-address: 172.16.0.0/12
  private-address: 192.168.0.0/16

  private-domain: "{{ network.base_domain }}."
  domain-insecure: "{{ network.base_domain }}."

  # ── КРИТИЧНО: снять дефолтные local-zone Unbound, иначе stub-зоны НЕ работают ──
  # У Unbound «из коробки» заведены local-zone типа static, которые отвечают
  # NXDOMAIN РАНЬШЕ, чем запрос дойдёт до stub-zone (local-zone обрабатываются
  # до итератора/форвардинга). Под эту блокировку попадают наши зоны:
  #   • home.arpa            → затеняет ВСЕ *.{{ network.base_domain }} (прямые имена)
  #   • AS112 RFC1918 reverse → затеняет наши PTR-stub (16-31.172.in-addr.arpa …)
  # insecure-lan-zones снимает только DNSSEC, но НЕ снимает саму блокировку —
  # поэтому нужны все три строки:
  local-zone: "{{ network.base_domain }}." transparent  # нет локальных данных → запрос проваливается в stub → pfSense
  unblock-lan-zones: yes                              # отключает фильтрацию приватных reverse → PTR-stub начинают работать
  insecure-lan-zones: yes                             # снимает DNSSEC-валидацию с приватных reverse (иначе SERVFAIL)

# ── stub-zones к pfSense ({{ pfsense_dns_ip }}) — ПРЯМЫЕ ──────────────────────────
# stub-addr — это адрес DNS-СЕРВИСА (pfSense), а не шлюза подсети; контейнер
# в MGMT, первый хоп = {{ pfsense_dns_ip }}, спрашиваем pfSense напрямую без inter-VLAN.
stub-zone:
  name: "{{ network.base_domain }}."
  stub-addr: {{ pfsense_dns_ip }}
  stub-prime: no
{% for label in segments.keys() %}
stub-zone:
  name: "{{ label }}.{{ network.base_domain }}."
  stub-addr: {{ pfsense_dns_ip }}
  stub-prime: no
{% endfor %}

# ── обратные зоны (PTR) — СТРОГО /24, не /16! ─────────────────────────────
# /16-делегирование увело бы на pfSense PTR соседних подсетей и сломало рекурсию.
{% for label, seg in segments.items() %}
{%   set octets = seg.cidr.split('/')[0].split('.') %}
{%   if seg.cidr.split('/')[1] == '24' %}
stub-zone:
  name: "{{ octets[2] }}.{{ octets[1] }}.{{ octets[0] }}.in-addr.arpa."   # {{ label }} ({{ seg.cidr }})
  stub-addr: {{ pfsense_dns_ip }}
  stub-prime: no
{%   else %}
# ВНИМАНИЕ: сегмент {{ label }} ({{ seg.cidr }}) не /24 — reverse stub пропущен,
# добавь логику генерации reverse-зон для этой маски вручную.
{%   endif %}
{% endfor %}

remote-control:
  control-enable: yes
  control-interface: 127.0.0.1
  control-port: 8953
  control-use-cert: no
