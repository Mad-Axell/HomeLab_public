{# Docker Compose for NetBox / Docker Compose для NetBox #}
{# Generated by Ansible - DO NOT EDIT MANUALLY #}
{# Сгенерировано Ansible - НЕ РЕДАКТИРОВАТЬ ВРУЧНУЮ #}

services:
  # NetBox application / Приложение NetBox
  netbox: &netbox
    image: docker.io/netboxcommunity/netbox:{{ netbox_version }}
    container_name: {{ netbox_container_prefix }}
    depends_on:
      - postgres
      - redis
      - redis-cache
    environment: &netbox-env
{% if netbox_api_token_pepper %}
      API_TOKEN_PEPPER_1: "{{ netbox_api_token_pepper }}"
{% endif %}
      CORS_ORIGIN_ALLOW_ALL: "{{ netbox_cors_origin_allow_all | string }}"
      DB_HOST: postgres
      DB_NAME: "{{ netbox_db_name }}"
      DB_PASSWORD: "{{ netbox_db_password }}"
      DB_USER: "{{ netbox_db_user }}"
      EMAIL_FROM: "{{ netbox_email_from }}"
      EMAIL_PASSWORD: "{{ netbox_email_password }}"
      EMAIL_PORT: "{{ netbox_email_port }}"
      EMAIL_SERVER: "{{ netbox_email_server }}"
      EMAIL_TIMEOUT: "{{ netbox_email_timeout }}"
      EMAIL_USERNAME: "{{ netbox_email_username }}"
      EMAIL_USE_SSL: "{{ netbox_email_use_ssl | lower }}"
      EMAIL_USE_TLS: "{{ netbox_email_use_tls | lower }}"
      GRANIAN_BACKPRESSURE: "{{ netbox_granian_backpressure }}"
      GRANIAN_WORKERS: "{{ netbox_granian_workers }}"
      GRAPHQL_ENABLED: "{{ netbox_graphql_enabled | lower }}"
      MEDIA_ROOT: /opt/netbox/netbox/media
      METRICS_ENABLED: "{{ netbox_metrics_enabled | lower }}"
      REDIS_CACHE_DATABASE: "1"
      REDIS_CACHE_HOST: redis-cache
      REDIS_CACHE_INSECURE_SKIP_TLS_VERIFY: "false"
      REDIS_CACHE_PASSWORD: "{{ netbox_redis_cache_password }}"
      REDIS_CACHE_SSL: "false"
      REDIS_DATABASE: "0"
      REDIS_HOST: redis
      REDIS_INSECURE_SKIP_TLS_VERIFY: "false"
      REDIS_PASSWORD: "{{ netbox_redis_password }}"
      REDIS_SSL: "false"
      RELEASE_CHECK_URL: "https://api.github.com/repos/netbox-community/netbox/releases"
      SECRET_KEY: "{{ netbox_secret_key }}"
      SKIP_SUPERUSER: "{{ netbox_skip_superuser | lower }}"
{% if not netbox_skip_superuser %}
      SUPERUSER_NAME: "{{ netbox_superuser_name }}"
      SUPERUSER_EMAIL: "{{ netbox_superuser_email }}"
      SUPERUSER_PASSWORD: "{{ netbox_superuser_password }}"
{% if netbox_superuser_api_token %}
      SUPERUSER_API_TOKEN: "{{ netbox_superuser_api_token }}"
{% endif %}
{% endif %}
      WEBHOOKS_ENABLED: "{{ netbox_webhooks_enabled | lower }}"
    user: "netbox:root"
    healthcheck:
      test: curl -f http://localhost:8080/login/ || exit 1
      start_period: 90s
      timeout: 3s
      interval: 15s
    ports:
      - "{{ netbox_port }}:8080"
    volumes:
      - netbox-media-files:/opt/netbox/netbox/media:rw
      - netbox-reports-files:/opt/netbox/netbox/reports:rw
      - netbox-scripts-files:/opt/netbox/netbox/scripts:rw
    restart: {{ netbox_restart_policy }}

  # NetBox background worker / Фоновый воркер NetBox
  netbox-worker:
    <<: *netbox
    container_name: {{ netbox_container_prefix }}-worker
    depends_on:
      netbox:
        condition: service_healthy
    command:
      - /opt/netbox/venv/bin/python
      - /opt/netbox/netbox/manage.py
      - rqworker
    ports: []
    healthcheck:
      test: ps -aux | grep -v grep | grep -q rqworker || exit 1
      start_period: 20s
      timeout: 3s
      interval: 15s

  # PostgreSQL database / База данных PostgreSQL
  postgres:
    image: docker.io/postgres:{{ netbox_postgres_version }}
    container_name: {{ netbox_container_prefix }}-postgres
    environment:
      POSTGRES_DB: "{{ netbox_db_name }}"
      POSTGRES_USER: "{{ netbox_db_user }}"
      POSTGRES_PASSWORD: "{{ netbox_db_password }}"
    healthcheck:
      test: pg_isready -q -t 2 -d $$POSTGRES_DB -U $$POSTGRES_USER
      start_period: 20s
      timeout: 30s
      interval: 10s
      retries: 5
    volumes:
      - netbox-postgres:/var/lib/postgresql
    restart: {{ netbox_restart_policy }}

  # Redis for task queues / Redis для очередей задач
  redis:
    image: docker.io/valkey/valkey:{{ netbox_valkey_version }}
    container_name: {{ netbox_container_prefix }}-redis
    command:
      - sh
      - -c
      - valkey-server --appendonly yes --requirepass $$REDIS_PASSWORD
    environment:
      REDIS_PASSWORD: "{{ netbox_redis_password }}"
    healthcheck: &redis-healthcheck
      test: '[ $$(valkey-cli --pass "$${REDIS_PASSWORD}" ping) = ''PONG'' ]'
      start_period: 5s
      timeout: 3s
      interval: 1s
      retries: 5
    volumes:
      - netbox-redis-data:/data
    restart: {{ netbox_restart_policy }}

  # Redis for caching / Redis для кэширования
  redis-cache:
    image: docker.io/valkey/valkey:{{ netbox_valkey_version }}
    container_name: {{ netbox_container_prefix }}-redis-cache
    command:
      - sh
      - -c
      - valkey-server --requirepass $$REDIS_PASSWORD
    environment:
      REDIS_PASSWORD: "{{ netbox_redis_cache_password }}"
    healthcheck: *redis-healthcheck
    volumes:
      - netbox-redis-cache-data:/data
    restart: {{ netbox_restart_policy }}

volumes:
  netbox-media-files:
    driver: local
  netbox-postgres:
    driver: local
  netbox-redis-data:
    driver: local
  netbox-redis-cache-data:
    driver: local
  netbox-reports-files:
    driver: local
  netbox-scripts-files:
    driver: local
