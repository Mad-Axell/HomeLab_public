# =============================================================================
# AdGuard Home Configuration
# Конфигурация AdGuard Home
# {{ ansible_managed }}
# =============================================================================

http:
  pprof:
    port: 6060
    enabled: false
  address: {{ adguard_web_bind }}:{{ adguard_web_port }}
  session_ttl: {{ adguard_session_ttl }}

# =============================================================================
# Users / Пользователи
# =============================================================================
{% if adguard_admin_password or adguard_admin_password_hash %}
users:
  - name: {{ adguard_admin_username }}
{% if adguard_admin_password_hash %}
    password: {{ adguard_admin_password_hash }}
{% else %}
    password: {{ adguard_admin_password | password_hash('bcrypt') }}
{% endif %}
{% else %}
users: []
{% endif %}

auth_attempts: {{ adguard_auth_attempts }}
block_auth_min: {{ adguard_block_auth_min }}

http_proxy: ""

language: "{{ adguard_language }}"

theme: {{ adguard_theme }}

# =============================================================================
# DNS Settings / Настройки DNS
# =============================================================================
dns:
  bind_hosts:
    - 0.0.0.0
  port: {{ adguard_dns_port }}

  # Upstream DNS servers / Вышестоящие DNS серверы
  upstream_dns:
{% for upstream in adguard_upstream_dns %}
    - {{ upstream }}
{% endfor %}

  # Fallback DNS servers / Резервные DNS серверы
{% if adguard_fallback_dns | length > 0 %}
  fallback_dns:
{% for fallback in adguard_fallback_dns %}
    - {{ fallback }}
{% endfor %}
{% else %}
  fallback_dns: []
{% endif %}

  # Bootstrap DNS (for resolving DoH/DoT hostnames)
  bootstrap_dns:
{% for bootstrap in adguard_bootstrap_dns %}
    - {{ bootstrap }}
{% endfor %}

  upstream_mode: load_balance

  fastest_timeout: 1s

  # Blocking settings / Настройки блокировки
  blocking_mode: {{ adguard_blocking_mode }}
{% if adguard_blocking_ipv4 %}
  blocking_ipv4: {{ adguard_blocking_ipv4 }}
{% endif %}
{% if adguard_blocking_ipv6 %}
  blocking_ipv6: {{ adguard_blocking_ipv6 }}
{% endif %}
  blocked_response_ttl: 10

  protection_enabled: true

  # Rate limit / Ограничение запросов
  ratelimit: {{ adguard_ratelimit }}
  ratelimit_subnet_len_ipv4: 24
  ratelimit_subnet_len_ipv6: 56
  ratelimit_whitelist: []

  # Refuse ANY queries / Отклонять ANY запросы
  refuse_any: true

  # EDNS client subnet
  edns_client_subnet:
    enabled: {{ adguard_edns_client_subnet | lower }}
    use_custom: false
    custom_ip: ""

  # Max concurrent goroutines
  max_goroutines: 300

  # Handle DDR queries
  handle_ddr: true

  # DNSSEC
  enable_dnssec: false  # DNSSEC handled by Unbound

  # Cache disabled (caching handled by Unbound)
  # Кэш отключен (кеширование выполняет Unbound)
  cache_size: 0
  cache_ttl_min: 0
  cache_ttl_max: 0
  cache_optimistic: false

  # Resolve clients
  resolve_clients: true

  # Use private PTR resolvers
  use_private_ptr_resolvers: true

  local_ptr_upstreams: []

  # Serve plain DNS on HTTP port
  serve_http3: false
  use_http3_upstreams: false

# =============================================================================
# TLS Settings / Настройки TLS
# =============================================================================
tls:
  enabled: false
  server_name: ""
  force_https: false
  port_https: 443
  port_dns_over_tls: 853
  port_dns_over_quic: 853
  port_dnscrypt: 0
  allow_unencrypted_doh: false
  certificate_chain: ""
  private_key: ""
  certificate_path: ""
  private_key_path: ""

# =============================================================================
# Query Log / Журнал запросов
# =============================================================================
querylog:
  enabled: {{ adguard_querylog_enabled | lower }}
  file_enabled: true
  interval: {{ adguard_querylog_interval }}
  size_memory: {{ adguard_querylog_size_memory }}
  ignored: []

# =============================================================================
# Statistics / Статистика
# =============================================================================
statistics:
  enabled: {{ adguard_stats_enabled | lower }}
  interval: {{ adguard_stats_interval }}
  ignored: []

# =============================================================================
# Filtering / Фильтрация
# =============================================================================
filtering:
  blocking_mode: {{ adguard_blocking_mode }}
  filtering_enabled: {{ adguard_filtering_enabled | lower }}
  parental_enabled: {{ adguard_parental_enabled | lower }}
  safebrowsing_enabled: {{ adguard_safebrowsing_enabled | lower }}

  safe_search:
    enabled: {{ adguard_safesearch_enabled | lower }}
{% if adguard_safesearch_enabled %}
{% for service in adguard_safesearch_services %}
    {{ service }}: true
{% endfor %}
{% endif %}

  safebrowsing_cache_size: 1048576
  safesearch_cache_size: 1048576
  parental_cache_size: 1048576
  cache_time: 30

  rewrites:
{% if adguard_dns_rewrites | length > 0 %}
{% for rewrite in adguard_dns_rewrites %}
    - domain: "{{ rewrite.domain }}"
      answer: "{{ rewrite.answer }}"
{% endfor %}
{% else %}
    []
{% endif %}

  blocked_services:
    schedule:
      time_zone: Local
    ids: []

# =============================================================================
# Filter Lists / Списки фильтров
# =============================================================================
filters:
{% for filter in adguard_blocklists + adguard_extra_blocklists %}
  - enabled: {{ filter.enabled | default(true) | lower }}
    url: {{ filter.url }}
    name: {{ filter.name }}
    id: {{ loop.index }}
{% endfor %}

# Allowlists / Списки разрешений
whitelist_filters:
{% if adguard_allowlists | length > 0 %}
{% for allow in adguard_allowlists %}
  - enabled: {{ allow.enabled | default(true) | lower }}
    url: {{ allow.url }}
    name: {{ allow.name }}
    id: {{ loop.index + 100 }}
{% endfor %}
{% else %}
  []
{% endif %}

# User rules / Пользовательские правила
user_rules:
{% if adguard_user_rules | length > 0 %}
{% for rule in adguard_user_rules %}
  - '{{ rule }}'
{% endfor %}
{% else %}
  []
{% endif %}

# =============================================================================
# DHCP Settings / Настройки DHCP
# =============================================================================
dhcp:
  enabled: false
  interface_name: ""
  local_domain_name: lan
  dhcpv4:
    gateway_ip: ""
    subnet_mask: ""
    range_start: ""
    range_end: ""
    lease_duration: 86400
    icmp_timeout_msec: 1000
    options: []
  dhcpv6:
    range_start: ""
    lease_duration: 86400
    ra_slaac_only: false
    ra_allow_slaac: false

# =============================================================================
# Clients / Клиенты
# =============================================================================
clients:
  runtime_sources:
    whois: true
    arp: true
    rdns: true
    dhcp: true
    hosts: true
  persistent: []

log:
  enabled: true
  file: ""
  max_backups: 0
  max_size: 100
  max_age: 3
  compress: false
  local_time: false
  verbose: false

os:
  group: ""
  user: ""
  rlimit_nofile: 0

schema_version: 28

