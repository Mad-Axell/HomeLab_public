#!/bin/bash
# =============================================================================
# DNS Health Check Script
# Скрипт проверки здоровья DNS
# {{ ansible_managed }}
# =============================================================================

set -euo pipefail

# Colors for output / Цвета для вывода
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

# Configuration / Конфигурация
UNBOUND_PORT={{ unbound_port }}
ADGUARD_PORT={{ adguard_dns_port }}
TEST_DOMAIN="example.com"
DNSSEC_FAIL_DOMAIN="dnssec-failed.org"

# Counters / Счётчики
CHECKS_PASSED=0
CHECKS_FAILED=0

# -----------------------------------------------------------------------------
# Helper functions / Вспомогательные функции
# -----------------------------------------------------------------------------
check_pass() {
    echo -e "${GREEN}✓${NC} $1"
    ((CHECKS_PASSED++))
}

check_fail() {
    echo -e "${RED}✗${NC} $1"
    ((CHECKS_FAILED++))
}

check_warn() {
    echo -e "${YELLOW}!${NC} $1"
}

# -----------------------------------------------------------------------------
# Check Unbound / Проверка Unbound
# -----------------------------------------------------------------------------
echo "=== Unbound DNS Resolver ==="

# Service status / Статус сервиса
if systemctl is-active --quiet unbound; then
    check_pass "Unbound service is running"
else
    check_fail "Unbound service is not running"
fi

# DNS resolution / Разрешение DNS
if dig @127.0.0.1 -p ${UNBOUND_PORT} ${TEST_DOMAIN} +short +time=5 > /dev/null 2>&1; then
    check_pass "Unbound resolves ${TEST_DOMAIN}"
else
    check_fail "Unbound cannot resolve ${TEST_DOMAIN}"
fi

# DNSSEC validation / Валидация DNSSEC
{% if unbound_dnssec_enabled %}
if dig @127.0.0.1 -p ${UNBOUND_PORT} ${DNSSEC_FAIL_DOMAIN} +dnssec +time=5 2>&1 | grep -q "SERVFAIL"; then
    check_pass "DNSSEC validation is working (rejects invalid signatures)"
else
    check_warn "DNSSEC validation might not be working"
fi
{% endif %}

# Cache stats / Статистика кэша
if command -v unbound-control &> /dev/null; then
    CACHE_HITS=$(unbound-control stats_noreset 2>/dev/null | grep "total.num.cachehits" | awk -F= '{print $2}' || echo "0")
    CACHE_MISS=$(unbound-control stats_noreset 2>/dev/null | grep "total.num.cachemiss" | awk -F= '{print $2}' || echo "0")
    if [ "$CACHE_HITS" != "0" ] || [ "$CACHE_MISS" != "0" ]; then
        TOTAL=$((CACHE_HITS + CACHE_MISS))
        if [ "$TOTAL" -gt 0 ]; then
            HIT_RATE=$((CACHE_HITS * 100 / TOTAL))
            echo "  Cache hit rate: ${HIT_RATE}% (${CACHE_HITS}/${TOTAL})"
        fi
    fi
fi

echo ""

# -----------------------------------------------------------------------------
# Check AdGuard Home / Проверка AdGuard Home
# -----------------------------------------------------------------------------
{% if ns_server_install_adguard %}
echo "=== AdGuard Home ==="

ADGUARD_API="http://127.0.0.1:{{ adguard_web_port }}"

# Service status / Статус сервиса
if systemctl is-active --quiet {{ adguardhome_service_name | default('adguardhome') }}; then
    check_pass "AdGuard Home service is running"
else
    check_fail "AdGuard Home service is not running"
fi

# DNS resolution / Разрешение DNS
if dig @127.0.0.1 -p ${ADGUARD_PORT} ${TEST_DOMAIN} +short +time=5 > /dev/null 2>&1; then
    check_pass "AdGuard Home resolves ${TEST_DOMAIN}"
else
    check_fail "AdGuard Home cannot resolve ${TEST_DOMAIN}"
fi

# Web interface / Веб-интерфейс
if curl -s --connect-timeout 5 "${ADGUARD_API}/control/status" > /dev/null 2>&1; then
    check_pass "AdGuard Home web interface is accessible"
else
    check_fail "AdGuard Home web interface is not accessible"
fi

# Protection status / Статус защиты
ADGUARD_STATUS=$(curl -s --connect-timeout 5 "${ADGUARD_API}/control/status" 2>/dev/null || echo "{}")
if echo "$ADGUARD_STATUS" | grep -q '"protection_enabled":true'; then
    check_pass "DNS protection is enabled"
else
    check_warn "DNS protection is disabled"
fi

# Filtering status / Статус фильтрации
if echo "$ADGUARD_STATUS" | grep -q '"filtering_enabled":true'; then
    check_pass "Filtering is enabled"
else
    check_warn "Filtering is disabled"
fi

# Ad blocking test / Тест блокировки рекламы
AD_TEST_DOMAIN="ads.google.com"
AD_RESULT=$(dig @127.0.0.1 -p ${ADGUARD_PORT} ${AD_TEST_DOMAIN} +short +time=5 2>/dev/null || echo "")
if [ "$AD_RESULT" = "0.0.0.0" ] || [ -z "$AD_RESULT" ]; then
    check_pass "Ad blocking is working (${AD_TEST_DOMAIN} blocked)"
else
    check_warn "Ad blocking might not be configured (${AD_TEST_DOMAIN} resolved to ${AD_RESULT})"
fi

# Statistics / Статистика
ADGUARD_STATS=$(curl -s --connect-timeout 5 "${ADGUARD_API}/control/stats" 2>/dev/null || echo "{}")
if [ -n "$ADGUARD_STATS" ] && [ "$ADGUARD_STATS" != "{}" ]; then
    DNS_QUERIES=$(echo "$ADGUARD_STATS" | grep -o '"num_dns_queries":[0-9]*' | cut -d: -f2 || echo "0")
    BLOCKED=$(echo "$ADGUARD_STATS" | grep -o '"num_blocked_filtering":[0-9]*' | cut -d: -f2 || echo "0")
    if [ -n "$DNS_QUERIES" ] && [ "$DNS_QUERIES" != "0" ]; then
        BLOCK_RATE=$((BLOCKED * 100 / DNS_QUERIES))
        echo "  DNS queries: ${DNS_QUERIES}, Blocked: ${BLOCKED} (${BLOCK_RATE}%)"
    fi
fi

# Upstream check / Проверка upstream
UPSTREAM_STATUS=$(curl -s --connect-timeout 5 "${ADGUARD_API}/control/dns_info" 2>/dev/null || echo "{}")
if echo "$UPSTREAM_STATUS" | grep -q '"upstream_dns"'; then
    UPSTREAM=$(echo "$UPSTREAM_STATUS" | grep -o '"upstream_dns":\[[^]]*\]' | head -1)
    if echo "$UPSTREAM" | grep -q "127.0.0.1:{{ unbound_port }}"; then
        check_pass "Upstream DNS is correctly set to Unbound (127.0.0.1:{{ unbound_port }})"
    else
        check_warn "Upstream DNS might not be configured to use Unbound"
    fi
fi

echo ""
{% endif %}

# -----------------------------------------------------------------------------
# Check cache persistence / Проверка сохранения кэша
# -----------------------------------------------------------------------------
{% if unbound_cache_dump_enabled %}
echo "=== Cache Persistence ==="

if [ -f "{{ unbound_cache_dump_file }}" ]; then
    CACHE_SIZE=$(du -h "{{ unbound_cache_dump_file }}" | cut -f1)
    CACHE_DATE=$(stat -c %y "{{ unbound_cache_dump_file }}" 2>/dev/null | cut -d'.' -f1)
    check_pass "Cache dump file exists (${CACHE_SIZE}, last updated: ${CACHE_DATE})"
else
    check_warn "Cache dump file does not exist yet"
fi

if systemctl is-active --quiet unbound-cache-dump.timer; then
    check_pass "Cache dump timer is active"
else
    check_fail "Cache dump timer is not active"
fi

echo ""
{% endif %}

# -----------------------------------------------------------------------------
# Response time test / Тест времени отклика
# -----------------------------------------------------------------------------
echo "=== Response Time ==="

# First query (cold cache or recursive)
TIME1=$(dig @127.0.0.1 -p ${UNBOUND_PORT} cloudflare.com +time=10 2>/dev/null | grep "Query time" | awk '{print $4}')
echo "  First query: ${TIME1:-N/A} msec"

# Second query (cached)
TIME2=$(dig @127.0.0.1 -p ${UNBOUND_PORT} cloudflare.com +time=10 2>/dev/null | grep "Query time" | awk '{print $4}')
echo "  Cached query: ${TIME2:-N/A} msec"

echo ""

# -----------------------------------------------------------------------------
# Summary / Итог
# -----------------------------------------------------------------------------
echo "=== Summary ==="
echo -e "Checks passed: ${GREEN}${CHECKS_PASSED}${NC}"
echo -e "Checks failed: ${RED}${CHECKS_FAILED}${NC}"

if [ ${CHECKS_FAILED} -eq 0 ]; then
    echo -e "\n${GREEN}All checks passed!${NC}"
    exit 0
else
    echo -e "\n${RED}Some checks failed!${NC}"
    exit 1
fi

